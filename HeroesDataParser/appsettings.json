{
  "Serilog": {
    "MinimumLevel": {
      // set to Verbose, Debug, Information, Warning, Error, or Fatal
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Polly": "Warning"
      }
    }
  },
  "RootOptions": {
    // set all to -1 for automatic detection
    "HeroesVersion": {
      "Major": -1,
      "Minor": -1,
      "Revision": -1,
      "Build": -1,
      "IsPtr": true
    },
    "StorageLoad": {
      "Type": "online", // 'mods', 'game', 'online'
      "Path": null, // path to game directory or extracted mods directory, set to null if using online
      "Ptr": false // only for online, set to 'true' to download from ptr server
    },
    "OutputDirectory": ".",
    "Extractors": {
      "Announcer": {
        "IsEnabled": false,
        "Images": false
      },
      "Banner": {
        "IsEnabled": false
      },
      "Boost": {
        "IsEnabled": false
      },
      "Bundle": {
        "IsEnabled": false,
        "Images": false
      },
      "Emoticon": {
        "IsEnabled": false,
        "Images": false
      },
      "EmoticonPack": {
        "IsEnabled": false
      },
      "Hero": {
        "IsEnabled": false,
        "Images": false
      },
      "LootChest": {
        "IsEnabled": false
      },
      "Map": {
        "IsEnabled": false,
        "Images": false
      },
      "MatchAward": {
        "IsEnabled": false,
        "Images": false
      },
      "Mount": {
        "IsEnabled": false
      },
      "PortraitPack": {
        "IsEnabled": false
      },
      "RewardPortrait": {
        "IsEnabled": false
      },
      "Skin": {
        "IsEnabled": false
      },
      "Spray": {
        "IsEnabled": false,
        "Images": false
      },
      "TypeDescription": {
        "IsEnabled": false,
        "Images": false
      },
      "Unit": {
        "IsEnabled": false,
        "Images": false
      },
      "Veterancy": {
        "IsEnabled": false
      },
      "VoiceLine": {
        "IsEnabled": false,
        "Images": false
      }
    },
    "Localizations": [
      "enUS"
      //"deDE",
      //"esES",
      //"esMX",
      //"frFR",
      //"itIT",
      //"koKR",
      //"plPL",
      //"ptBR",
      //"ruRU",
      //"zhCN",
      //"zhTW"
    ],
    "LocalizedText": "None", // 0 = None, 1 = Extract, 2 = Copy
    "GameStringText": {
      "Type": 0, // 0 = RawText, 1 = PlainText, 2 = PlainTextWithNewlines, 3 = PlainTextWithScaling, 4 = PlainTextWithScalingWithNewlines, 5 = ColoredText, 6 = ColoredTextWithScaling
      "ReplaceFontStyles": false,

      // if ReplaceFontStyles is false, these properties will all be false
      "PreserveFont": {
        "PreserveFontStyleConstantVars": false,
        "PreserveFontStyleVars": false
      }
    },
    "MapSpecificWriterJsonOutputType": "Diff", // 0 = None, 1 = Normal, 2 = Diff, 3 = All
    "AllowEmptyMapSpecificDiffFiles": false,
    "AllowEmptyMapSpecificDirectories": false,
    "ShowLoadedCustomConfigFiles": false,
    "Threads": -1, // -1 = automatic detection/no limit
    "Hidden": {
      "AllowHeroHiddenAbilities": false,
      "AllowHeroSpecialAbilities": false, // Taunt, Dance, Spray, Voice abilities

      "AnimatedImageType": "apng", // 'gif' or 'apng'

      // for individual image extracting, these are shared for heroes and units
      "Abilities": false,
      "AbilityTalents": false,

      // for individual image extracting
      "HeroImages": {
        "HeroPortraits": false,
        "Talents": false,
        "HeroData": true, // HeroPortraits | AbilityTalents
        "HeroDataSplit": false // HeroPortraits | Abilities | Talents
      },

      // for individual image extracting
      "UnitImages": {
        "UnitPortraits": false,
        "UnitData": true // UnitPortraits | AbilityTalents
      },

      // for individual image extracting
      "MapImages": {
        "ReplayPreviews": true,
        "LoadingScreens": true,
        "MapObjectiveIcons": true
      }
    }
  }
}
