{
  "Serilog": {
    "MinimumLevel": {
      // set to Verbose, Debug, Information, Warning, Error, or Fatal
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Polly": "Warning"
      }
    }
  },
  "RootOptions": {
    "Hidden": {
      "AllowHeroHiddenAbilities": false,
      "AllowHeroSpecialAbilities": false, // Taunt, Dance, Spray, Voice abilities

      "AnimatedImageType": "apng", // 'gif' or 'apng'

      // for individual image extracting, these are shared for heroes and units
      "Abilities": false,
      "AbilityTalents": false,

      // for individual image extracting
      "HeroImages": {
        "HeroPortraits": false,
        "Talents": false,
        "HeroData": true, // HeroPortraits | AbilityTalents
        "HeroDataSplit": false // HeroPortraits | Abilities | Talents
      },

      // for individual image extracting
      "UnitImages": {
        "UnitPortraits": false,
        "UnitData": true // UnitPortraits | AbilityTalents
      },

      // for individual image extracting
      "MapImages": {
        "ReplayPreviews": true,
        "LoadingScreens": true,
        "MapObjectiveIcons": true
      }
    }
  }
}
