{
  "RootOptions": {
    "HeroesVersion": {
      "Major": -1,
      "Minor": -1,
      "Revision": -1,
      "Build": -1,
      "IsPtr": true
    },
    "StorageLoad": {
      "Type": "online", // 'mods', 'game', 'online'
      "Path": null // path to game directory or extracted mods directory, set to null if using online
    },
    "OutputDirectory": ".",
    "Extractors": {
      "Announcer": {
        "IsEnabled": false,
        "Images": false
      },
      "Banner": {
        "IsEnabled": false,
        "Images": false
      },
      "Bundle": {
        "IsEnabled": false,
        "Images": false
      },
      "Boost": {
        "IsEnabled": false,
        "Images": false
      },
      "Hero": {
        "IsEnabled": false,
        "Images": false
      },
      "LootChest": {
        "IsEnabled": false,
        "Images": false
      },
      "Map": {
        "IsEnabled": false,
        "Images": false
      },
      "Unit": {
        "IsEnabled": false,
        "Images": false
      }
    },
    "Localizations": [
      "enUS"
      //"deDE",
      //"esES",
      //"esMX",
      //"frFR",
      //"itIT",
      //"koKR",
      //"plPL",
      //"ptBR",
      //"ruRU",
      //"zhCN",
      //"zhTW"
    ],
    "LocalizedText": "None", // 0 = None, 1 = Extract, 2 = Copy
    "GameStringText": {
      "Type": 0, // 0 = RawText, 1 = PlainText, 2 = PlainTextWithNewlines, 3 = PlainTextWithScaling, 4 = PlainTextWithScalingWithNewlines, 5 = ColoredText, 6 = ColoredTextWithScaling
      "ReplaceFontStyles": false,

      // if ReplaceFontStyles is false, these properties will all be false
      "PreserveFont": {
        "PreserveFontStyleConstantVars": false,
        "PreserveFontStyleVars": false
      }
    },
    "Hidden": {
      "AllowHeroHiddenAbilities": false,
      "AllowHeroSpecialAbilities": false, // Taunt, Dance, Spray, Voice abilities

      // for individual extracting of images instead of all
      "HeroImages": {
        "HeroPortraits": false,
        "Talents": false,
        "Abilities": false,
        "AbilityTalents": false,
        "HeroData": true, // HeroPortrait | AbilityTalent
        "HeroDataSplit": false // HeroPortrait | Ability | Talent
      },
      "MapImages": {
        "ReplayPreviews": true,
        "LoadingScreens": true,
        "MapObjectiveIcons": true
      }
    }
  }
}
