<?xml version="1.0" encoding="utf-8" ?>
<Behavior>
  <CBehavior default="1">
    <Name value="Behavior/Name/##id##" />
    <Tooltip value="Behavior/Tooltip/##id##" />
    <InfoIcon value="Assets\Textures\btn-missing-kaeo.dds" />
    <MinStackCountDisplayed value="2" />
  </CBehavior>
  <CBehaviorAbility id="DeathwingFormSwitchAbility">
    <Buttons Face="DeathwingFormSwitch" Type="AbilCmd" AbilCmd="DeathwingFormSwitch,Execute" />
  </CBehaviorAbility>
  <CBehaviorAbility id="NecromancerBoneArmor">
    <Buttons Face="NecromancerBoneArmor" Type="AbilCmd" AbilCmd="NecromancerBoneArmor,Execute" ShowValidator="DoesNotHaveNecromancerBoneArmorTalentsOrHasBoneArmorShadeTalent" />
    <Buttons Face="NecromancerBoneArmorAbilBacklash" Type="AbilCmd" AbilCmd="NecromancerBoneArmor,Execute" ShowValidator="HasNecromancerTalentBacklash" />
    <Buttons Face="NecromancerBoneArmorAbilShackler" Type="AbilCmd" AbilCmd="NecromancerBoneArmor,Execute" ShowValidator="HasNecromancerTalentShackler" />
  </CBehaviorAbility>
  <CBehaviorTokenCounter id="RagnarosCatchingFireTokenCounter" parent="StormQuestToken">
    <Face value="RagnarosCatchingFireQuest" />
    <Max value="15" />
    <AtMaxEvents index="0" EventId="QuestComplete" Effect="RagnarosCatchingFireAbilityAvailabilityControllerApplyBehavior" />
    <SortIndex value="20" />
  </CBehaviorTokenCounter>
  <CBehaviorBuff id="RagnarosCatchingFireRegenIncreaseCarryBehavior" parent="CarryBehaviorParent">
    <Modification>
      <VitalRegenArray index="Life" value="0">
        <AccumulatorArray value="RagnarosCatchingFireTalentAccumulator" />
      </VitalRegenArray>
    </Modification>
  </CBehaviorBuff>
  <CBehaviorAbility id="RagnarosCatchingFireItem">
    <Buttons Face="RagnarosCatchingFireItem" Type="AbilCmd" AbilCmd="RagnarosCatchingFire,Execute" />
    <DisableValidatorArray value="RagnarosHasMaxCatchingFireTokens" />
  </CBehaviorAbility>
  <CBehaviorAbility id="JunkratTotalMayhemDirtyTricksterItem">
    <Buttons Face="JunkratDirtyTrickster" Type="AbilCmd" AbilCmd="JunkratTotalMayhemDirtyTrickster,Execute" />
  </CBehaviorAbility>
  <CBehaviorAbility id="AnubarakLegionOfBeetlesItem">
    <Buttons Face="AnubarakScarabHostToggleLegionOfBeetlesOn" Type="AbilCmd" AbilCmd="AnubarakLegionOfBeetlesToggle,Off" />
    <Buttons Face="AnubarakScarabHostToggleLegionOfBeetlesOff" Type="AbilCmd" AbilCmd="AnubarakLegionOfBeetlesToggle,On" />
  </CBehaviorAbility>
  <CBehaviorBuff id="Ultimate1Unlocked">
  </CBehaviorBuff>
  <CBehaviorBuff id="Ultimate2Unlocked">
  </CBehaviorBuff>
  <CBehaviorBuff id="Ultimate3Unlocked">
  </CBehaviorBuff>
</Behavior>
